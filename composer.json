{
    "name": "web-best-practice/posts",
    "description": "Laravel package for managing blog posts",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Web Best Practice",
            "email": "marcin@webbestpractice.co.uk"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "WebBestPractice\\Posts\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "WebBestPractice\\Posts\\PostsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}